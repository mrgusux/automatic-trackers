# EditorConfig is awesome: https://EditorConfig.org

# Top-most EditorConfig file
root = true

# Defaults for every file: Unix newlines, UTF-8, 2-space indentation
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 2

# Makefiles REQUIRE real tabs for recipe lines.
# Without this override, editors would insert spaces and `make` would
# fail with the infamous "*** missing separator" error.
[{Makefile,makefile,GNUmakefile,*.mk}]
indent_style = tab

# Shell scripts & bats test files (shell-like syntax)
[*.{sh,bash,bats}]
indent_style = space
indent_size = 2

# YAML (workflows, configs) - indentation is syntax in YAML
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON (api outputs, configs) - also covers .all-contributorsrc
[{*.json,.all-contributorsrc}]
indent_style = space
indent_size = 2

# Markdown: two trailing spaces are meaningful (hard line break)
[*.md]
trim_trailing_whitespace = false

# Generated tracker text outputs - leave their content untouched
[*.txt]
trim_trailing_whitespace = false
insert_final_newline = false
